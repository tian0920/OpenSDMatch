[Unit]
Description=OpenSDMatch annotation web
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/ecs-user/OpenSDMatch
ExecStart=/home/ecs-user/miniconda3/envs/OpenSDMatch/bin/python /home/ecs-user/OpenSDMatch/sampling/annotation_web.py --csv /home/ecs-user/OpenSDMatch/sampling/annotation_pairs_blind.csv --host 0.0.0.0 --port 8765 --replicates 2
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
